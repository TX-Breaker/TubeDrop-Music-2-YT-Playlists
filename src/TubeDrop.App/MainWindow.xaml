<ui:FluentWindow x:Class="TubeDrop.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
                 Title="TubeDrop"
                 Icon="pack://application:,,,/tubedrop.ico"
                 Width="1120" Height="740"
                 MinWidth="880" MinHeight="580"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource TubeDrop.Brush.Bg}"
                 ExtendsContentIntoTitleBar="True">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="TubeDrop">
      <ui:TitleBar.Icon>
        <ui:ImageIcon Source="pack://application:,,,/tubedrop.ico" Width="18" Height="18" />
      </ui:TitleBar.Icon>
    </ui:TitleBar>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Navigation rail (§12) — skin-driven, DynamicResource only -->
      <Border Grid.Column="0" Background="{DynamicResource TubeDrop.Brush.Rail}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="0,0,1,0">
        <DockPanel Margin="8,10,8,10">
          <StackPanel DockPanel.Dock="Bottom">
            <Border Height="1" Background="{DynamicResource TubeDrop.Brush.Stroke}" Margin="6,8" />

            <!-- Not signed in: sign-in button -->
            <Button HorizontalAlignment="Stretch" Height="40" BorderThickness="0"
                    Background="Transparent"
                    Foreground="{DynamicResource TubeDrop.Brush.Text2}"
                    Command="{Binding SignInCommand}"
                    Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Person24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Common_SignIn], Source={StaticResource Loc}}"
                           FontSize="10" HorizontalAlignment="Center" />
              </StackPanel>
            </Button>

            <!-- Signed in: avatar → account menu popup -->
            <Grid HorizontalAlignment="Center"
                  Visibility="{Binding IsSignedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
              <ToggleButton x:Name="AccountToggle" Width="40" Height="40" BorderThickness="0"
                            Background="Transparent" Cursor="Hand"
                            ToolTip="{Binding AccountName}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Grid Width="34" Height="34">
                      <Ellipse Fill="{DynamicResource TubeDrop.Brush.Accent}" />
                      <TextBlock Text="{Binding AccountInitial}" FontWeight="Bold" FontSize="14"
                                 Foreground="{DynamicResource TubeDrop.Brush.OnAccent}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Visibility="{Binding HasAvatar, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                      <Ellipse Visibility="{Binding HasAvatar, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse.Fill>
                          <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                      </Ellipse>
                    </Grid>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>

              <Popup PlacementTarget="{Binding ElementName=AccountToggle}" Placement="Top"
                     StaysOpen="False" AllowsTransparency="True"
                     IsOpen="{Binding IsChecked, ElementName=AccountToggle, Mode=TwoWay}">
                <Border Margin="8" Padding="6" MinWidth="200"
                        Background="{DynamicResource TubeDrop.Brush.Card2}"
                        BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
                        CornerRadius="{DynamicResource TubeDrop.Radius.Md}">
                  <StackPanel>
                    <TextBlock Text="{Binding [Common_SignedIn], Source={StaticResource Loc}}"
                               Foreground="{DynamicResource TubeDrop.Brush.Good}" Margin="8,6,8,0" />
                    <TextBlock Text="{Binding AccountName}" Margin="8,0,8,6" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TubeDrop.Brush.Text2}"
                               Visibility="{Binding AccountName, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Border Height="1" Background="{DynamicResource TubeDrop.Brush.Stroke}" Margin="4,4" />
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Height="34" BorderThickness="0" Background="Transparent"
                            Foreground="{DynamicResource TubeDrop.Brush.Text}"
                            Command="{Binding SwitchAccountCommand}"
                            Content="{Binding [Account_Switch], Source={StaticResource Loc}}" />
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Height="34" BorderThickness="0" Background="Transparent"
                            Foreground="{DynamicResource TubeDrop.Brush.Text}"
                            Command="{Binding SignOutCommand}"
                            Content="{Binding [Account_SignOut], Source={StaticResource Loc}}" />
                  </StackPanel>
                </Border>
              </Popup>
            </Grid>
          </StackPanel>

          <StackPanel>
            <StackPanel.Resources>
              <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="Height" Value="58" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TubeDrop.Brush.Text2}" />
                <Setter Property="Command" Value="{Binding NavigateCommand}" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="Bd" CornerRadius="{DynamicResource TubeDrop.Radius.Md}"
                              Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TubeDrop.Brush.Card2}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </StackPanel.Resources>

            <Button Style="{StaticResource NavButton}" CommandParameter="Home">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Home24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Nav_Home], Source={StaticResource Loc}}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" CommandParameter="Queue">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="TaskListLtr24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Nav_Queue], Source={StaticResource Loc}}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" CommandParameter="Report">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="DocumentBulletList24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Nav_Report], Source={StaticResource Loc}}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" CommandParameter="Activity">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="History24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Nav_Activity], Source={StaticResource Loc}}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" CommandParameter="Settings">
              <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Settings24" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding [Nav_Settings], Source={StaticResource Loc}}" FontSize="10.5" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Button>
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" Background="{DynamicResource TubeDrop.Brush.Bg}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
          <Border Margin="18,12,18,0" Padding="14,10"
                  CornerRadius="{DynamicResource TubeDrop.Radius.Md}"
                  Background="{DynamicResource TubeDrop.Brush.AccentSoft}"
                  Visibility="{Binding SessionExpiredBannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding [Common_SessionExpired], Source={StaticResource Loc}}"
                         Foreground="{DynamicResource TubeDrop.Brush.Text}" VerticalAlignment="Center" />
              <Button Content="{Binding [Common_SignIn], Source={StaticResource Loc}}"
                      Margin="14,0,0,0" Command="{Binding SignInCommand}" />
            </StackPanel>
          </Border>

          <Border Margin="18,12,18,0" Padding="14,10"
                  CornerRadius="{DynamicResource TubeDrop.Radius.Md}"
                  Background="{DynamicResource TubeDrop.Brush.AccentSoft}"
                  Visibility="{Binding UpdateBannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding UpdateVersion, StringFormat='Update available: {0}'}"
                         Foreground="{DynamicResource TubeDrop.Brush.Text}" VerticalAlignment="Center" />
              <Button Content="Update &amp; restart" Margin="14,0,0,0" Command="{Binding ApplyUpdateCommand}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <ContentControl Grid.Row="1" Margin="18,12,18,16" Content="{Binding CurrentViewModel}" />
      </Grid>
    </Grid>
  </Grid>
</ui:FluentWindow>
