<UserControl x:Class="TubeDrop.App.Views.Pages.ActivityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ActivityViewModel}"
             d:DesignWidth="860" d:DesignHeight="640">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="{Binding [Activity_Title], Source={StaticResource Loc}}" FontSize="22" FontWeight="SemiBold"
               Foreground="{DynamicResource TubeDrop.Brush.Text}" Margin="2,0,0,10" />

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Sessions -->
      <Border Grid.Column="0" Margin="0,0,12,0" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <ListView ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                  Margin="6" BorderThickness="0" Background="{x:Null}">
          <ListView.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="2,4">
                <TextBlock Text="{Binding StartedAt}" Foreground="{DynamicResource TubeDrop.Brush.Text}" />
                <TextBlock Text="{Binding OperationCount, StringFormat='{}{0} operations'}"
                           FontSize="11" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <!-- Operations -->
      <Border Grid.Column="1" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <DataGrid ItemsSource="{Binding Operations}" AutoGenerateColumns="False" Margin="6"
                  Background="{x:Null}" BorderThickness="0" GridLinesVisibility="None"
                  HeadersVisibility="Column" IsReadOnly="True" RowBackground="Transparent"
                  Foreground="{DynamicResource TubeDrop.Brush.Text}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="90" />
            <DataGridTextColumn Header="Operation" Binding="{Binding Type}" Width="*" />
            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
            <DataGridTemplateColumn Header="" Width="80">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="{Binding [Activity_Undo], Source={StaticResource Loc}}" Padding="8,2"
                          Command="{Binding DataContext.UndoOperationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding OperationId}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
      <Button Content="{Binding [Activity_UndoSession], Source={StaticResource Loc}}" Command="{Binding UndoSessionCommand}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="14,0,0,0"
                 Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
    </StackPanel>
  </Grid>
</UserControl>
