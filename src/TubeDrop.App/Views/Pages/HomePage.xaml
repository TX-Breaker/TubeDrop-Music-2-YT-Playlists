<UserControl x:Class="TubeDrop.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
             d:DesignWidth="900" d:DesignHeight="720"
             Focusable="True" KeyDown="HomePage_OnKeyDown">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid MaxWidth="880" Margin="0,4,0,20" HorizontalAlignment="Stretch">
      <StackPanel>

        <!-- Header -->
        <TextBlock Text="{Binding [Home_DropHere], Source={StaticResource Loc}}"
                   FontSize="26" FontWeight="Bold"
                   Foreground="{DynamicResource TubeDrop.Brush.Text}" />
        <TextBlock Text="{Binding [Home_Subtitle], Source={StaticResource Loc}}"
                   Foreground="{DynamicResource TubeDrop.Brush.Text2}" Margin="0,4,0,18" />

        <!-- Hero drop zone -->
        <Grid x:Name="DropZone" MinHeight="190" AllowDrop="True"
              Background="Transparent"
              Drop="DropZone_OnDrop" DragOver="DropZone_OnDragOver">
          <Rectangle RadiusX="14" RadiusY="14"
                     Fill="{DynamicResource TubeDrop.Brush.Surface}"
                     Stroke="{DynamicResource TubeDrop.Brush.Stroke2}"
                     StrokeThickness="2" StrokeDashArray="5 3" />
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
            <Border Width="76" Height="76" CornerRadius="20"
                    Background="{DynamicResource TubeDrop.Brush.AccentSoft}"
                    HorizontalAlignment="Center">
              <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="34"
                             Foreground="{DynamicResource TubeDrop.Brush.Accent}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding [Home_DropFormats], Source={StaticResource Loc}}"
                       FontSize="13" Margin="0,18,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
            <ui:ProgressRing IsIndeterminate="True" Width="26" Height="26" Margin="0,12,0,0"
                             Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </StackPanel>
        </Grid>

        <!-- Files-ready banner -->
        <Border Margin="0,14,0,0" Padding="10,8"
                Background="{DynamicResource TubeDrop.Brush.AccentSoft}"
                BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
                CornerRadius="{DynamicResource TubeDrop.Radius.Md}"
                Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6"
                    Background="{DynamicResource TubeDrop.Brush.Accent}" VerticalAlignment="Center">
              <TextBlock Text="{Binding TrackCount}" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource TubeDrop.Brush.OnAccent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Grid.Column="1" Text="{Binding Summary}" VerticalAlignment="Center" Margin="10,0,0,0"
                       Foreground="{DynamicResource TubeDrop.Brush.Text}" />
            <Button Grid.Column="2" Style="{StaticResource TubeDrop.GhostButton}"
                    Content="{Binding [Home_Clear], Source={StaticResource Loc}}"
                    Command="{Binding ResetCommand}" />
          </Grid>
        </Border>

        <!-- Track list (with manual remove) -->
        <Border Margin="0,10,0,0"
                Background="{DynamicResource TubeDrop.Brush.Card}"
                BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
                CornerRadius="{DynamicResource TubeDrop.Radius.Card}"
                Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ItemsControl ItemsSource="{Binding Tracks}" Margin="6">
            <ItemsControl.Template>
              <ControlTemplate TargetType="ItemsControl">
                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                  <ItemsPresenter />
                </ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="4,4" Height="46">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Width="38" Height="38" CornerRadius="7" VerticalAlignment="Center"
                          Background="{DynamicResource TubeDrop.Brush.AccentSoft}">
                    <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TubeDrop.Brush.Accent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TubeDrop.Brush.Text}" />
                    <TextBlock Text="{Binding Detail}" FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
                  </StackPanel>
                  <Button Grid.Column="2" Style="{StaticResource TubeDrop.IconButton}"
                          VerticalAlignment="Center"
                          ToolTip="{Binding [Home_RemoveTrack], Source={StaticResource Loc}}"
                          Command="{Binding DataContext.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" />
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <!-- Destination card -->
        <Border Margin="0,16,0,0" Padding="18"
                Background="{DynamicResource TubeDrop.Brush.Card}"
                BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
                CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
          <StackPanel>
            <TextBlock Text="{Binding [Home_Destination], Source={StaticResource Loc}}"
                       FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"
                       Foreground="{DynamicResource TubeDrop.Brush.Text}" />

            <!-- Target segmented control -->
            <Border Style="{StaticResource TubeDrop.SegmentBar}" HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal">
                <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="target"
                             Content="{Binding [Home_CreateNew], Source={StaticResource Loc}}"
                             IsChecked="{Binding CreateNew}" />
                <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="target"
                             Content="{Binding [Home_AppendExisting], Source={StaticResource Loc}}"
                             Checked="AppendRadio_OnChecked" />
              </StackPanel>
            </Border>

            <!-- Create-new block -->
            <StackPanel Margin="0,14,0,0"
                        Visibility="{Binding CreateNew, Converter={StaticResource BooleanToVisibilityConverter}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Height="42" VerticalContentAlignment="Center"
                            Text="{Binding PlaylistName, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding NameFromFolder, Converter={StaticResource InverseBooleanConverter}}"
                            PlaceholderText="{Binding [Home_Name], Source={StaticResource Loc}}" />
                <Border Grid.Column="1" Style="{StaticResource TubeDrop.SegmentBar}" Margin="8,0,0,0">
                  <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="priv"
                                 Content="{Binding [Home_Private], Source={StaticResource Loc}}"
                                 IsChecked="{Binding Privacy, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Private}" />
                    <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="priv"
                                 Content="{Binding [Home_Unlisted], Source={StaticResource Loc}}"
                                 IsChecked="{Binding Privacy, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Unlisted}" />
                    <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="priv"
                                 Content="{Binding [Home_Public], Source={StaticResource Loc}}"
                                 IsChecked="{Binding Privacy, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Public}" />
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Folder-naming toggle row -->
              <Border Margin="0,12,0,0" Padding="12,10"
                      Background="{DynamicResource TubeDrop.Brush.Surface}"
                      BorderBrush="{DynamicResource TubeDrop.Brush.Stroke2}" BorderThickness="1"
                      CornerRadius="{DynamicResource TubeDrop.Radius.Md}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <ui:ToggleSwitch Grid.Column="0" VerticalAlignment="Center"
                                   IsChecked="{Binding NameFromFolder}"
                                   IsEnabled="{Binding FolderNamingAvailable}" />
                  <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Home_NameFromFolder], Source={StaticResource Loc}}"
                               Foreground="{DynamicResource TubeDrop.Brush.Text}" />
                    <TextBlock Text="{Binding DerivedFolderNote}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TubeDrop.Brush.Warn}"
                               Visibility="{Binding DerivedFolderNote, Converter={StaticResource BooleanToVisibilityConverter}}" />
                  </StackPanel>
                  <Border Grid.Column="2" Style="{StaticResource TubeDrop.SegmentBar}"
                          Visibility="{Binding NameFromFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                      <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="foldermode" Content="Master"
                                   IsChecked="{Binding FolderMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Master}" />
                      <RadioButton Style="{StaticResource TubeDrop.Segment}" GroupName="foldermode" Content="Subfolder"
                                   IsChecked="{Binding FolderMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Subfolder}" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </StackPanel>

            <!-- Append block -->
            <StackPanel Margin="0,14,0,0"
                        Visibility="{Binding CreateNew, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
              <Grid Margin="0,0,0,6">
                <TextBlock Text="{Binding [Home_PickPlaylist], Source={StaticResource Loc}}"
                           Foreground="{DynamicResource TubeDrop.Brush.Text2}" VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" Style="{StaticResource TubeDrop.GhostButton}"
                        Content="{Binding [Home_Refresh], Source={StaticResource Loc}}"
                        Command="{Binding LoadLibraryCommand}" />
              </Grid>
              <ComboBox ItemsSource="{Binding ExistingPlaylists}"
                        SelectedItem="{Binding SelectedExistingPlaylist}"
                        DisplayMemberPath="Title"
                        IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" />
              <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,8,0,0" HorizontalAlignment="Left"
                               Visibility="{Binding IsLoadingLibrary, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <TextBlock Text="{Binding LibraryHint}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                         Foreground="{DynamicResource TubeDrop.Brush.Text3}"
                         Visibility="{Binding LibraryHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Start -->
        <Button Margin="0,18,0,0" HorizontalAlignment="Right" MinWidth="200"
                Style="{StaticResource TubeDrop.PrimaryButton}"
                Command="{Binding StartBatchCommand}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding StartButtonText}" VerticalAlignment="Center" />
            <Border Margin="10,0,0,0" Padding="8,2" CornerRadius="20"
                    Background="{DynamicResource TubeDrop.Brush.OnAccentBadge}"
                    Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="{Binding TrackCount}" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource TubeDrop.Brush.OnAccent}" />
            </Border>
          </StackPanel>
        </Button>

      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
