<UserControl x:Class="TubeDrop.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
             xmlns:playlists="clr-namespace:TubeDrop.Core.Playlists;assembly=TubeDrop.Core"
             xmlns:ingestion="clr-namespace:TubeDrop.Core.Ingestion;assembly=TubeDrop.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
             d:DesignWidth="900" d:DesignHeight="680"
             Focusable="True" KeyDown="HomePage_OnKeyDown">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="320" />
    </Grid.ColumnDefinitions>

    <!-- Left: drop + list -->
    <Grid Grid.Column="0" Margin="0,0,14,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="2,0,0,12">
        <TextBlock Text="{Binding [Home_Title], Source={StaticResource Loc}}" FontSize="26" FontWeight="SemiBold"
                   Foreground="{DynamicResource TubeDrop.Brush.Text}" />
        <TextBlock Text="{Binding [Home_Subtitle], Source={StaticResource Loc}}"
                   Foreground="{DynamicResource TubeDrop.Brush.Text2}" Margin="0,2,0,0" />
      </StackPanel>

      <Border Grid.Row="1" x:Name="DropZone" AllowDrop="True"
              Drop="DropZone_OnDrop" DragOver="DropZone_OnDragOver"
              Background="{DynamicResource TubeDrop.Brush.Surface}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke2}"
              BorderThickness="2" CornerRadius="{DynamicResource TubeDrop.Radius.Lg}"
              MinHeight="160" Padding="24">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <ui:SymbolIcon Symbol="MusicNote224" FontSize="46"
                         Foreground="{DynamicResource TubeDrop.Brush.Accent}" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding StatusText}" FontSize="15" Margin="0,12,0,0"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}" />
          <ui:ProgressRing IsIndeterminate="True" Width="26" Height="26" Margin="0,10,0,0"
                           Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Margin="0,12,0,0"
              Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}"
              Visibility="{Binding HasFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
        <ListView ItemsSource="{Binding Tracks}" Margin="8" BorderThickness="0" Background="{x:Null}">
          <ListView.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,3">
                <TextBlock Text="{Binding Display}" Foreground="{DynamicResource TubeDrop.Brush.Text}" />
                <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>
    </Grid>

    <!-- Right: target picker (§9) -->
    <Border Grid.Column="1" Background="{DynamicResource TubeDrop.Brush.Card}"
            BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
            CornerRadius="{DynamicResource TubeDrop.Radius.Card}" Padding="18">
      <StackPanel>
        <TextBlock Text="{Binding [Home_Destination], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"
                   Foreground="{DynamicResource TubeDrop.Brush.Text}" Margin="0,0,0,12" />

        <RadioButton Content="{Binding [Home_CreateNew], Source={StaticResource Loc}}" GroupName="target"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}"
                     IsChecked="{Binding CreateNew}" Margin="0,0,0,6" />
        <RadioButton Content="{Binding [Home_AppendExisting], Source={StaticResource Loc}}" GroupName="target"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}"
                     IsChecked="{Binding CreateNew, Converter={StaticResource InverseBooleanConverter}, Mode=OneWay}"
                     Checked="AppendRadio_OnChecked" />

        <!-- Create-new block -->
        <StackPanel Visibility="{Binding CreateNew, Converter={StaticResource BooleanToVisibilityConverter}}">
          <TextBlock Text="{Binding [Home_Name], Source={StaticResource Loc}}" Margin="0,16,0,4" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
          <TextBox Text="{Binding PlaylistName, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding NameFromFolder, Converter={StaticResource InverseBooleanConverter}}" />

          <CheckBox Content="{Binding [Home_NameFromFolder], Source={StaticResource Loc}}" Margin="0,12,0,0"
                    Foreground="{DynamicResource TubeDrop.Brush.Text}"
                    IsChecked="{Binding NameFromFolder}"
                    IsEnabled="{Binding FolderNamingAvailable}" />
          <StackPanel Orientation="Horizontal" Margin="24,6,0,0"
                      Visibility="{Binding NameFromFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
            <RadioButton Content="Master" GroupName="foldermode" Margin="0,0,12,0"
                         Foreground="{DynamicResource TubeDrop.Brush.Text2}"
                         IsChecked="{Binding FolderMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Master}" />
            <RadioButton Content="Subfolder" GroupName="foldermode"
                         Foreground="{DynamicResource TubeDrop.Brush.Text2}"
                         IsChecked="{Binding FolderMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Subfolder}" />
          </StackPanel>
          <TextBlock Text="{Binding DerivedFolderNote}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                     Foreground="{DynamicResource TubeDrop.Brush.Warn}"
                     Visibility="{Binding DerivedFolderNote, Converter={StaticResource BooleanToVisibilityConverter}}" />

          <TextBlock Text="{Binding [Home_Privacy], Source={StaticResource Loc}}" Margin="0,16,0,4" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
          <ComboBox ItemsSource="{Binding Privacies}" SelectedItem="{Binding Privacy}" />
        </StackPanel>

        <!-- Append block -->
        <StackPanel Visibility="{Binding CreateNew, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
          <Grid Margin="0,16,0,4">
            <TextBlock Text="{Binding [Home_PickPlaylist], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
            <Button HorizontalAlignment="Right" Padding="8,0" FontSize="11"
                    Content="{Binding [Home_Refresh], Source={StaticResource Loc}}"
                    Command="{Binding LoadLibraryCommand}" />
          </Grid>
          <ComboBox ItemsSource="{Binding ExistingPlaylists}"
                    SelectedItem="{Binding SelectedExistingPlaylist}"
                    DisplayMemberPath="Title"
                    IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True" />
          <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,8,0,0" HorizontalAlignment="Left"
                           Visibility="{Binding IsLoadingLibrary, Converter={StaticResource BooleanToVisibilityConverter}}" />
          <TextBlock Text="{Binding LibraryHint}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                     Foreground="{DynamicResource TubeDrop.Brush.Text3}"
                     Visibility="{Binding LibraryHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Button Margin="0,22,0,0" Height="46" HorizontalAlignment="Stretch"
                Background="{DynamicResource TubeDrop.Brush.Accent}"
                Foreground="{DynamicResource TubeDrop.Brush.OnAccent}"
                BorderThickness="0"
                Command="{Binding StartBatchCommand}">
          <TextBlock Text="{Binding [Home_CreateButton], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14" />
        </Button>
        <Button Margin="0,8,0,0" Height="34" HorizontalAlignment="Stretch"
                Content="{Binding [Home_Reset], Source={StaticResource Loc}}"
                Command="{Binding ResetCommand}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
