<UserControl x:Class="TubeDrop.App.Views.Pages.ReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ReportViewModel}"
             d:DesignWidth="860" d:DesignHeight="640">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Summary cards -->
    <ItemsControl Grid.Row="0" Margin="0,0,0,12">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <Border Margin="0,0,8,0" Padding="14" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <StackPanel>
          <TextBlock Text="{Binding AddedCount}" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TubeDrop.Brush.Good}" />
          <TextBlock Text="{Binding [Report_Added], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
        </StackPanel>
      </Border>
      <Border Margin="0,0,8,0" Padding="14" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <StackPanel>
          <TextBlock Text="{Binding FallbackCount}" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TubeDrop.Brush.Warn}" />
          <TextBlock Text="{Binding [Report_Fallback], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
        </StackPanel>
      </Border>
      <Border Margin="0,0,8,0" Padding="14" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <StackPanel>
          <TextBlock Text="{Binding UnmatchedCount}" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}" />
          <TextBlock Text="{Binding [Report_Unmatched], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
        </StackPanel>
      </Border>
      <Border Margin="0,0,8,0" Padding="14" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <StackPanel>
          <TextBlock Text="{Binding DuplicateCount}" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}" />
          <TextBlock Text="{Binding [Report_Duplicates], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
        </StackPanel>
      </Border>
      <Border Padding="14" Background="{DynamicResource TubeDrop.Brush.Card}"
              BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
              CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
        <StackPanel>
          <TextBlock Text="{Binding SkippedCount}" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource TubeDrop.Brush.Text}" />
          <TextBlock Text="{Binding [Report_Skipped], Source={StaticResource Loc}}" Foreground="{DynamicResource TubeDrop.Brush.Text2}" />
        </StackPanel>
      </Border>
    </ItemsControl>

    <!-- Filter + export -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
      <ComboBox Width="150" ItemsSource="{Binding Filters}" SelectedItem="{Binding Filter}" />
      <Button Content="{Binding [Report_ExportCsv], Source={StaticResource Loc}}" Margin="10,0,0,0" Command="{Binding ExportCsvCommand}" />
      <Button Content="{Binding [Report_ExportJson], Source={StaticResource Loc}}" Margin="8,0,0,0" Command="{Binding ExportJsonCommand}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="14,0,0,0"
                 Foreground="{DynamicResource TubeDrop.Brush.Text2}" TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <!-- Table -->
    <Border Grid.Row="2" Background="{DynamicResource TubeDrop.Brush.Card}"
            BorderBrush="{DynamicResource TubeDrop.Brush.Stroke}" BorderThickness="1"
            CornerRadius="{DynamicResource TubeDrop.Radius.Card}">
      <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" Margin="6"
                Background="{x:Null}" BorderThickness="0" GridLinesVisibility="None"
                HeadersVisibility="Column" IsReadOnly="True"
                RowBackground="Transparent" Foreground="{DynamicResource TubeDrop.Brush.Text}">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="Status" Width="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}"
                           Foreground="{Binding StatusBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Track" Binding="{Binding Title}" Width="*" />
          <DataGridTextColumn Header="Matched" Binding="{Binding MatchedTitle}" Width="*" />
          <DataGridTextColumn Header="Confidence"
                              Binding="{Binding Confidence, Converter={StaticResource ConfidenceToTextConverter}}" Width="90" />
          <DataGridTemplateColumn Header="" Width="210">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <Button Content="{Binding [Report_Open], Source={StaticResource Loc}}" Padding="8,2" Margin="0,0,4,0"
                          Command="{Binding DataContext.OpenVideoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding VideoId}" />
                  <Button Content="{Binding [Report_Search], Source={StaticResource Loc}}" Padding="8,2" Margin="0,0,4,0"
                          ToolTip="Search this track on YouTube"
                          Command="{Binding DataContext.ManualSearchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                  <Button Content="{Binding [Report_Remove], Source={StaticResource Loc}}" Padding="8,2"
                          ToolTip="Remove from the playlist (undoable)"
                          Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
