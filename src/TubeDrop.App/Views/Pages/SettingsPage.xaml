<UserControl x:Class="TubeDrop.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TubeDrop.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             d:DesignWidth="820" d:DesignHeight="640">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="2">
      <StackPanel.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
          <Setter Property="Foreground" Value="{DynamicResource TubeDrop.Brush.Text2}" />
          <Setter Property="Margin" Value="0,14,0,4" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Section">
          <Setter Property="Foreground" Value="{DynamicResource TubeDrop.Brush.Text}" />
          <Setter Property="FontSize" Value="16" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Margin" Value="0,20,0,4" />
        </Style>
      </StackPanel.Resources>

      <TextBlock Text="{Binding [Settings_Title], Source={StaticResource Loc}}" FontSize="22" FontWeight="SemiBold"
                 Foreground="{DynamicResource TubeDrop.Brush.Text}" />

      <TextBlock Text="{Binding [Settings_Appearance], Source={StaticResource Loc}}" Style="{StaticResource Section}" Margin="0,16,0,4" />
      <TextBlock Text="{Binding [Settings_Skin], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left"
                ItemsSource="{Binding Skins}" SelectedItem="{Binding Skin}" />
      <CheckBox Content="{Binding [Settings_LightTheme], Source={StaticResource Loc}}" Margin="0,12,0,0"
                Foreground="{DynamicResource TubeDrop.Brush.Text}"
                IsChecked="{Binding IsLightTheme}" IsEnabled="{Binding LightSupported}" />
      <TextBlock Text="Noir is dark-only." FontSize="11"
                 Foreground="{DynamicResource TubeDrop.Brush.Text3}"
                 Visibility="{Binding LightSupported, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

      <TextBlock Text="{Binding [Settings_Language], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left"
                ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}" />

      <TextBlock Text="{Binding [Settings_Matching], Source={StaticResource Loc}}" Style="{StaticResource Section}" />
      <TextBlock Text="{Binding [Settings_SearchScope], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left"
                ItemsSource="{Binding Scopes}" SelectedItem="{Binding SearchScope}" />
      <TextBlock Text="{Binding ScoreThreshold, StringFormat='Score threshold: {0:0.00}'}"
                 Style="{StaticResource Label}" />
      <Slider Width="260" HorizontalAlignment="Left" Minimum="0.5" Maximum="0.95"
              TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding ScoreThreshold}" />
      <CheckBox Content="{Binding [Settings_Aggressive], Source={StaticResource Loc}}"
                Margin="0,12,0,0" Foreground="{DynamicResource TubeDrop.Brush.Text}"
                IsChecked="{Binding AggressiveMode}" />

      <TextBlock Text="{Binding [Settings_Fallback], Source={StaticResource Loc}}" Style="{StaticResource Section}" />
      <CheckBox Content="{Binding [Settings_Onnx], Source={StaticResource Loc}}"
                Foreground="{DynamicResource TubeDrop.Brush.Text}"
                IsChecked="{Binding OnnxRefinerEnabled}" />
      <CheckBox Content="{Binding [Settings_Cloud], Source={StaticResource Loc}}" Margin="0,10,0,0"
                Foreground="{DynamicResource TubeDrop.Brush.Text}"
                IsChecked="{Binding CloudRefinerEnabled}" />
      <TextBlock Text="Cloud API key" Style="{StaticResource Label}"
                 Visibility="{Binding CloudRefinerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <PasswordBox x:Name="CloudKeyBox" Width="320" HorizontalAlignment="Left"
                   PasswordChanged="CloudKeyBox_OnPasswordChanged"
                   Visibility="{Binding CloudRefinerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

      <CheckBox Content="{Binding [Settings_AcoustId], Source={StaticResource Loc}}" Margin="0,12,0,0"
                Foreground="{DynamicResource TubeDrop.Brush.Text}"
                IsChecked="{Binding AcoustIdEnabled}" />
      <TextBlock Text="{Binding [Settings_AcoustIdMissing], Source={StaticResource Loc}}" FontSize="11" TextWrapping="Wrap"
                 Foreground="{DynamicResource TubeDrop.Brush.Warn}" Margin="0,4,0,0"
                 Visibility="{Binding FingerprinterAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
      <TextBlock Text="{Binding [Settings_AcoustIdKey], Source={StaticResource Loc}}" Style="{StaticResource Label}"
                 Visibility="{Binding AcoustIdEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <PasswordBox x:Name="AcoustIdKeyBox" Width="320" HorizontalAlignment="Left"
                   PasswordChanged="AcoustIdKeyBox_OnPasswordChanged"
                   Visibility="{Binding AcoustIdEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

      <TextBlock Text="{Binding [Settings_Playlists], Source={StaticResource Loc}}" Style="{StaticResource Section}" />
      <TextBlock Text="{Binding [Settings_DefaultPrivacy], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left"
                ItemsSource="{Binding Privacies}" SelectedItem="{Binding DefaultPrivacy}" />

      <TextBlock Text="{Binding [Settings_Network], Source={StaticResource Loc}}" Style="{StaticResource Section}" />
      <TextBlock Text="{Binding [Settings_RateLimit], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left"
                ItemsSource="{Binding RateProfiles}" SelectedItem="{Binding RateLimitProfile}" />
      <TextBlock Text="{Binding [Settings_UpdateChannel], Source={StaticResource Loc}}" Style="{StaticResource Label}" />
      <ComboBox Width="220" HorizontalAlignment="Left" Margin="0,0,0,20"
                ItemsSource="{Binding Channels}" SelectedItem="{Binding UpdateChannel}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
